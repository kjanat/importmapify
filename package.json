{
	"name": "importmapify",
	"version": "0.1.0",
	"description": "Expand package.json subpath-pattern imports into explicit Deno import map entries.",
	"keywords": ["deno", "import-map", "importmap", "subpath-imports", "cli"],
	"homepage": "https://github.com/kjanat/importmapify#readme",
	"bugs": "https://github.com/kjanat/importmapify/issues",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/kjanat/importmapify.git"
	},
	"license": "MIT",
	"author": {
		"name": "Kaj Kowalski",
		"email": "info@kajkowalski.nl",
		"url": "https://github.com/kjanat"
	},
	"sideEffects": false,
	"type": "module",
	"bin": {
		"importmapify": "./dist/cli.js"
	},
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"default": "./dist/index.js"
		},
		"./package.json": "./package.json"
	},
	"types": "./dist/index.d.ts",
	"files": ["dist"],
	"scripts": {
		"bd": "tsdown",
		"build": "tsdown",
		"build:watch": "tsdown --watch",
		"check": "biome check",
		"fmt": "dprint fmt",
		"lint": "biome lint",
		"prepublishOnly": "[ -n \"${GITHUB_ACTIONS:-}\" ] || { printf '%s\\n' 'manual npm publish blocked; use release workflow for provenance' >&2; exit 1; }",
		"test": "bun test --coverage",
		"test:watch": "bun test --watch",
		"typecheck": "tsc --noEmit -p tsconfig.json"
	},
	"devDependencies": {
		"@arethetypeswrong/core": "^0.18.5",
		"@biomejs/biome": "2.5.2 || ^2.5.4",
		"@kjanat/dreamcli": "3.0.0-rc.9",
		"@types/bun": "^1.3.14",
		"@types/node": "^26.1.1",
		"dprint": "^0.55.2",
		"publint": "^0.3.21",
		"tsdown": "^0.22.7",
		"typescript": "npm:typescript@>=6,<7",
		"unplugin-unused": "^0.5.7"
	},
	"packageManager": "bun@1.3.14",
	"devEngines": {
		"packageManager": [
			{ "name": "bun", "version": ">=1.3", "onFail": "warn" },
			{ "name": "npm", "version": ">=11,<12", "onFail": "warn" }
		],
		"runtime": [
			{ "name": "node", "version": ">=20" },
			{ "name": "bun", "version": ">=1.3" }
		]
	}
}
